# =============================================================================
# Kinderspielstadt Server – Environment Configuration
# Copy to .env and adjust values. Never commit .env with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
# Bind address. Use 0.0.0.0 to accept external connections.

PORT=5000
# Listen port.

DEBUG=false
# true = Flask dev server with auto-reload. false = Waitress WSGI server (production).

THREADS=4
# Number of Waitress worker threads (only when DEBUG=false).

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here
# Required for sessions/signing. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"

# -----------------------------------------------------------------------------
# MariaDB
# -----------------------------------------------------------------------------
MARIADB_HOST=localhost
# Database host.

MARIADB_PORT=3306
# Database port.

MARIADB_USER=root
# Database user.

MARIADB_PASSWORD=your-password
# Database password.

MARIADB_DATABASE=kinderspielstadt
# Database name.