# =============================================================================
# Kinderspielstadt Los Ämmerles (LA-Server) – Environment Configuration
# Copy to .env and adjust values. Never commit .env with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# LA-Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
# Bind address. Use 0.0.0.0 to accept external connections.

PORT=5000
# Listen port.

DEBUG=false
# true = Flask dev server with auto-reload. false = Waitress WSGI server (production).

THREADS=4
# Number of Waitress worker threads.
# Also, if 'DEBUG=true' and 'THREADS=0', then the Flask dev server runs not threaded

LOG_LEVEL=INFO
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.

# LOG_FILE=
# Optional absolute or relative path for rotating log files (10 MB x 5 backups).
# Omit to log only to stderr. Under the hood, a queue listener thread writes
# the file so worker threads do not contend on the same file handle.

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here
# Required for sessions/signing. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"

# -----------------------------------------------------------------------------
# Other
# -----------------------------------------------------------------------------
VALIDATE_CHECK_SUM=true
# true = Employee_number contains a check sum which is validated

# -----------------------------------------------------------------------------
# MariaDB
# -----------------------------------------------------------------------------
MARIADB_HOST=localhost
# Database host.

MARIADB_PORT=3306
# Database port.

MARIADB_USER=root
# Database user.

MARIADB_PASSWORD=your-password
# Database password.

MARIADB_DATABASE=kinderspielstadt
# Database name.
